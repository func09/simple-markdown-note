{
  "name": "simple-markdown-note",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "Simple Markdown Note - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "format": "turbo format",
    "lint": "turbo lint",
    "check": "turbo check",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean:cache": "find . -name \"*.tsbuildinfo\" -delete",
    "check:all": "pnpm clean:cache && turbo check typecheck test --force",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Mitsuru Haga",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.7.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignore": [
        "prisma",
        "@prisma/client"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "typescript": "5.7.3",
      "@tanstack/react-query": "5.96.1",
      "@tanstack/react-query-devtools": "5.96.1",
      "zustand": "5.0.12",
      "hono": "4.12.9",
      "zod": "4.3.6",
      "vitest": "3.2.4",
      "@vitejs/plugin-react": "6.0.1"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ]
  }
}
