{
  "name": "simplenote-clone",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "tsx packages/database/seed.ts"
  },
  "description": "SimpleNote Clone - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "format": "pnpm -r --if-present format",
    "format:check": "pnpm -r --if-present format:check",
    "test": "pnpm -r --if-present test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "chai": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "loupe": "^3.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "prettier --write"
    ]
  }
}
