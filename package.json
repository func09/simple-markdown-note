{
  "name": "simple-markdown-note",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "Simple Markdown Note - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "check:all": "pnpm clean:cache && turbo check check:types test --force && pnpm check:react-compiler",
    "check:docs": "eslint \"**/*.{ts,tsx}\"",
    "check:react-compiler": "react-compiler-healthcheck apps/web/src apps/mobile/src",
    "check:types": "turbo check:types",
    "clean:cache": "find . -name \"*.tsbuildinfo\" -delete",
    "dev": "turbo run dev --filter=@simple-markdown-note/api --filter=@simple-markdown-note/web",
    "dev:all": "rm -rf apps/web/node_modules/.vite && turbo run dev",
    "prepare": "husky",
    "test": "CI=true turbo test",
    "test:cov": "CI=true turbo test -- --coverage --reporter=dot --silent"
  },
  "keywords": [],
  "author": "Mitsuru Haga",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bcryptjs": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.3",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "react-compiler-healthcheck": "^1.0.0",
    "tsx": "catalog:",
    "turbo": "^2.9.5",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.1",
    "vitest": "catalog:"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignore": [
        "prisma",
        "@prisma/client"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "markdown-it": "^12.3.2",
      "esbuild": "^0.25.0",
      "@tootallnate/once": "^3.0.1"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "eslint"
    ]
  }
}
