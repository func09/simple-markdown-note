{
  "name": "simplenote-clone",
  "version": "1.0.0",
  "private": true,
  "description": "SimpleNote Clone - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "format": "pnpm -F '*' format",
    "lint": "pnpm -F '*' lint",
    "check": "pnpm -F '*' check",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "chai": "^5.2.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "loupe": "^3.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.7",
    "wrangler": "^4.78.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignore": [
        "prisma",
        "@prisma/client"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ]
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ]
  }
}
