{
  "name": "simplenote-clone",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "SimpleNote Clone - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "format": "turbo format",
    "lint": "turbo lint",
    "check": "turbo check",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "chai": "^5.2.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "loupe": "^3.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "vitest": "^3.0.7",
    "wrangler": "^4.79.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignore": [
        "prisma",
        "@prisma/client"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "typescript": "6.0.2"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ]
  }
}
