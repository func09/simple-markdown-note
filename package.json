{
  "name": "simple-markdown-note",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "Simple Markdown Note - A robust, local-first note-taking app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "check:all": "pnpm clean:cache && turbo check check:types test --force",
    "check:docs": "eslint \"**/*.{ts,tsx}\"",
    "check:types": "turbo check:types",
    "clean:cache": "find . -name \"*.tsbuildinfo\" -delete",
    "dev": "tsx scripts/dev.ts",
    "prepare": "husky",
    "test": "CI=true turbo test",
    "test:cov": "CI=true turbo test -- --coverage --reporter=dot --silent"
  },
  "keywords": [],
  "author": "Mitsuru Haga",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "4.1.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignore": [
        "prisma",
        "@prisma/client"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "typescript": "6.0.2",
      "@tanstack/react-query": "5.96.2",
      "@tanstack/react-query-devtools": "5.96.2",
      "zustand": "5.0.12",
      "hono": "4.12.12",
      "zod": "4.3.6",
      "vitest": "4.1.3",
      "@vitejs/plugin-react": "6.0.1",
      "markdown-it": "^12.3.2",
      "esbuild": "^0.25.0",
      "@tootallnate/once": "^3.0.1"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "eslint"
    ]
  }
}
