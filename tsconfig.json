{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "incremental": true,
    "paths": {
      "@/api/*": ["./apps/api/src/*"],
      "@/web/*": ["./apps/web/src/*"],
      "@/desktop/*": ["./apps/desktop/src/*"],
      "@/database/*": ["./packages/database/src/*"],
      "@/database": ["./packages/database/src/index.ts"]
    }
  }
}
