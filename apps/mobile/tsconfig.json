{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["node", "@cloudflare/workers-types", "jest"],
    "paths": {
      "@/*": ["./src/*"],
      "@simple-markdown-note/schemas": ["../../packages/schemas/src/index.ts"],
      "@simple-markdown-note/schemas/*": ["../../packages/schemas/src/*"],
      "@simple-markdown-note/api-client": [
        "../../packages/api-client/src/index.ts"
      ],
      "@simple-markdown-note/api-client/*": ["../../packages/api-client/src/*"]
    }
  },
  "include": ["src", "**/*.ts", "**/*.tsx", "nativewind-env.d.ts"]
}
