    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests --coverage --silent",
    "web": "expo start --web"
  },
  "dependencies": {
