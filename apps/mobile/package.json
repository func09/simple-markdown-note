{
  "name": "@simple-markdown-note/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "check": "biome check .",
    "check:types": "tsc --noEmit",
    "dev": "expo start",
    "ios": "expo run:ios",
