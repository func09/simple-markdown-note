# JWT Secret (for local development)
JWT_SECRET="development-secret-key"

# CORS allowed origin
ALLOWED_ORIGIN="http://localhost:3000"

# Resend Mail Service Settings
RESEND_API_KEY="re_xxxxxxxxxxxxxx"
CLIENT_URL="http://localhost:3000"
# For testing locally without a verified domain, you must use "onboarding@resend.dev"
# For production after verifying your domain, use something like "noreply@yourdomain.com"
EMAIL_FROM="onboarding@resend.dev"
