{
  "name": "@simple-markdown-note/api",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "check": "biome check .",
    "check:types": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply simple-markdown-note-db",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --ip 0.0.0.0 --show-interactive-dev-session=false",
    "test": "vitest run",
    "test:cov": "vitest run --coverage --reporter=dot --silent"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@simple-markdown-note/database": "workspace:*",
    "@simple-markdown-note/emails": "workspace:*",
    "@simple-markdown-note/schemas": "workspace:*",
    "hono": "catalog:",
    "resend": "^6.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@hono/node-server": "^1.19.13",
    "@hono/swagger-ui": "^0.6.1",
    "vitest": "catalog:",
    "vitest-fetch-mock": "^0.4.5",
    "wrangler": "catalog:"
  },
  "license": "MIT"
}
