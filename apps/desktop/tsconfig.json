{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/desktop": ["./src/index.ts"],
      "@/desktop/*": ["./src/*"],
      "@/database": ["../../packages/database/src/index.ts"],
      "@/database/*": ["../../packages/database/src/*"]
    }
  },
  "include": ["src/**/*"]
}
