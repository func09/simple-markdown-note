{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Electron shell for Simplenote Clone",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "pnpm run build && electron .",
    "build": "tsc",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "package": "VITE_ELECTRON=true dotenv -e .env.production -- pnpm -F web build && pnpm run build && electron-builder build --mac --arm64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "api": "workspace:*",
    "database": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3"
  }
}
