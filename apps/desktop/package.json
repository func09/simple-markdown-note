{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Electron shell for Simplenote Clone",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "pnpm run build && electron .",
    "build": "tsc",
    "package": "electron-builder",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "typescript": "^5.0.0"
  }
}
