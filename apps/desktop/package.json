{
  "name": "@simple-markdown-note/desktop",
  "version": "1.0.0",
  "description": "Electron shell for SimpleMarkdownNote",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "check": "biome check .",
    "check:types": "tsc --noEmit",
    "dev": "pnpm run build && electron .",
    "package": "VITE_ELECTRON=true dotenv -e .env.production -- pnpm -F web build && pnpm run build && electron-builder build --mac --arm64",
    "start": "electron .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage --reporter=dot --silent"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@simple-markdown-note/api": "workspace:*",
    "@simple-markdown-note/database": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:",
    "dotenv-cli": "^11.0.0",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
