{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "db:check": {
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "build:cf": {
      "dependsOn": ["build"],
      "outputs": [".vercel/output/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "check:types": {
      "dependsOn": ["^check:types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalDependencies": ["pnpm-lock.yaml"]
}
