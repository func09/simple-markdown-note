{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@simple-markdown-note/api-client/*": ["./src/*"],
      "@simple-markdown-note/api": ["../../apps/api/src/index.ts"],
      "@simple-markdown-note/api/*": ["../../apps/api/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "vitest.config.ts"]
}
