{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node", "@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "api": ["../../apps/api/src/index.ts"],
