{
  "name": "@simple-markdown-note/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "check": "biome check .",
    "check:types": "tsc --noEmit",
    "db:check": "drizzle-kit check",
    "db:generate:migration": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:cov": "vitest run --coverage --reporter=dot --silent"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.30.5",
    "drizzle-seed": "^0.2.1",
    "tsx": "^4.21.0",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@simple-markdown-note/schemas": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.40.0"
  }
}
