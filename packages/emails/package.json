    "@react-email/tailwind": "2.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "react-email": "5.2.10",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  },
  "license": "MIT"
}
