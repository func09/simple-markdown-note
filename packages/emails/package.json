{
  "name": "@simple-markdown-note/emails",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "email export --dir src/templates",
    "check": "biome check .",
